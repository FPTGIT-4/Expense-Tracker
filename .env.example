# Environment Variables Template
# Copy this file to .env and fill in the values

# Secret key for Django application (keep it secret!)
SECRET_KEY=django-insecure-your-secret-key-here

# Run with DEBUG=True for local development, False for production
DEBUG=True

# Database connection URL (Use your Neon connection string)
# Example Postgres URL format:
# postgres://username:password@hostname:port/database_name?sslmode=require
DATABASE_URL=postgres://username:password@hostname:port/database_name?sslmode=require

# Allowed hosts (comma-separated list, e.g., mydomain.com,anotherdomain.com)
# ALLOWED_HOSTS=localhost,127.0.0.1
